@article{novelmethod,
  title = {A Novel Method for the Functionalization of Aminoacids L-Glycine, l-Glutamic Acid and l-Arginine on Maghemite/Magnetite Nanoparticles},
  author = {Bruno, A. J. and Correa, J. R. and Peláez-Abellán, E. and Urones-Garrote, E.},
  date = {2018-06-15},
  journaltitle = {Journal of Magnetism and Magnetic Materials},
  shortjournal = {Journal of Magnetism and Magnetic Materials},
  volume = {456},
  pages = {87--91},
  issn = {0304-8853},
  doi = {10.1016/j.jmmm.2018.02.010},
  url = {https://www.sciencedirect.com/science/article/pii/S0304885317322898},
  urldate = {2026-04-22},
  abstract = {Nanoparticles of maghemite/magnetite functionalized with l-glycine, l-glutamic acid and l-arginine were synthesized by a novel method. The novel procedure consists in an alternative of that reported by Massart for the precipitation of magnetite in which the aminoacid is added in the carboxylate form. The amounts of aminoacid in the initial molar concentrations were 35\%, 45\% and 65\% with respect to the ferrophase. The obtained nanoparticles were characterized by several techniques: X-ray diffraction (XRD), Fourier transform IR spectroscopy (FT-IR), transmission electron microscopy (TEM), Electron energy-loss spectroscopy (EELS) and magnetometry. The IR spectroscopy confirmed that the selected aminoacids were functionalized on the surface of iron oxide. XRD and EELS confirm that iron oxide consists of a maghemite-magnetite intermediate phase with an average particle size about 6\,nm, which was measured by transmission electron microscopy. The superparamagnetic character of the nanoparticles was evaluated by magnetometry.},
  keywords = {Aminoacid,Functionalization,Maghemite,Magnetite},
  file = {/home/delta/Zotero/storage/7SRKICKD/S0304885317322898.html}
}
